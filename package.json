{
  "name": "3dpmon",
  "version": "2.2.1016",
  "description": "3Dプリンタ監視ダッシュボード - Electron版",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "start:http": "python -m http.server 8313",
    "sync-version": "node scripts/sync-version.js",
    "prebuild": "node scripts/sync-version.js",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir",
    "test": "vitest run",
    "test:e2e": "node tests/e2e/electron_boot.test.mjs",
    "test:all": "vitest run && node tests/e2e/electron_boot.test.mjs",
    "test:watch": "vitest",
    "lint": "eslint 3dp_lib/",
    "lint:css": "stylelint \"*.css\"",
    "format": "prettier --check \"3dp_lib/**/*.js\" \"*.css\""
  },
  "author": "pumpCurry",
  "license": "BSD-3-Clause",
  "build": {
    "appId": "jp.542.3dpmon",
    "productName": "3dpmon",
    "copyright": "Copyright © 2025-2026 pumpCurry / 5r4ce2",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "3dp_monitor.html",
      "3dp_monitor.css",
      "3dp_panel.css",
      "favicon.ico",
      "3dp_lib/**/*",
      "electron/**/*",
      "build/icon-source.png",
      "node_modules/**/*",
      "!node_modules/electron/**",
      "!node_modules/electron-builder/**",
      "!**/*.tmp.*",
      "!**/*.map"
    ],
    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "build/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "3dpmon",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "language": "1041",
      "multiLanguageInstaller": true,
      "license": "build/license_ja.txt",
      "include": "build/installer.nsh",
      "artifactName": "${productName}-${version}-setup.${ext}",
      "uninstallDisplayName": "${productName} ${version}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}",
      "requestExecutionLevel": "user"
    }
  },
  "dependencies": {
    "gridstack": "^10.3.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-jsdoc": "^50.0.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.4.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^37.0.0",
    "vitest": "^3.0.0"
  }
}
